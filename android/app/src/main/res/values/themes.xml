<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Dark phosphor-green theme matching the web app -->
    <style name="Theme.Grunstahl" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#4dff91</item>
        <item name="colorPrimaryVariant">#1a5c35</item>
        <item name="colorOnPrimary">#0a0e0a</item>
        <item name="colorSecondary">#ffb347</item>
        <item name="colorOnSecondary">#0a0e0a</item>
        <item name="colorSurface">#0f150f</item>
        <item name="colorOnSurface">#c8e6c8</item>
        <item name="android:colorBackground">#0a0e0a</item>
        <item name="android:statusBarColor">#0f150f</item>
        <item name="android:navigationBarColor">#0f150f</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Monospace text style used throughout -->
    <style name="TextMono">
        <item name="android:fontFamily">monospace</item>
        <item name="android:textColor">#c8e6c8</item>
    </style>

    <style name="TextMono.Dim">
        <item name="android:textColor">#5a7a5a</item>
        <item name="android:textSize">11sp</item>
    </style>

    <style name="TextMono.Green">
        <item name="android:textColor">#4dff91</item>
    </style>

    <style name="TextMono.Amber">
        <item name="android:textColor">#ffb347</item>
    </style>

</resources>
